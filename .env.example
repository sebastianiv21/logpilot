# LogPilot — copy to .env and set values

# PostgreSQL connection string (required — replaces QDRANT_URL and DATA_DIR)
# When running via Docker Compose, this is set automatically in docker-compose.yaml.
# Override here only when running the backend outside Docker.
# DATABASE_URL=postgresql://logpilot:logpilot@localhost:5432/logpilot

# Required for AI agent (report generation and knowledge search):
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
EMBEDDING_MODEL=

# Optional: override when running backend locally (defaults used in Docker)
# LOKI_URL=http://localhost:3100
# PROMETHEUS_URL=http://localhost:9090
# Knowledge source paths. `KNOWLEDGE_CODE_SOURCES` and `KNOWLEDGE_DOC_SOURCES`
# support comma-separated paths; local runs use host paths as-is.
# Docker: set KNOWLEDGE_MOUNT_ROOT to the common parent mounted at /knowledge.
# KNOWLEDGE_CODE_SOURCES=/path/to/repo-one,/path/to/repo-two
# KNOWLEDGE_DOC_SOURCES=/path/to/docs-one,/path/to/docs-two
# KNOWLEDGE_MOUNT_ROOT=/path/to/parent   # Docker only, for multiple paths
