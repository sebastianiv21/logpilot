# LogPilot — copy to .env and set values

# PostgreSQL connection string (required — replaces QDRANT_URL and DATA_DIR)
# When running via Docker Compose, this is set automatically in docker-compose.yaml.
# Override here only when running the backend outside Docker.
# DATABASE_URL=postgresql://logpilot:logpilot@localhost:5432/logpilot

# Required for AI agent (report generation and knowledge search):
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
EMBEDDING_MODEL=

# Optional: override when running backend locally (defaults used in Docker)
# LOKI_URL=http://localhost:3100
# PROMETHEUS_URL=http://localhost:9090
# SESSION_RETENTION_ENABLED=true
# SESSION_RETENTION_MAX_COUNT=20
# SESSION_RETENTION_MAX_AGE_DAYS=30
# PROMETHEUS_RETENTION_TIME=30d
# Vector parser sidecar (dual-write).
#
# Backend drops every extracted log file under <VECTOR_LOG_DROP_DIR> so the
# Vector container can re-parse and push to Loki with parser="vector".
# Inside docker-compose this is wired automatically to /var/log/logpilot
# via the vector-logs named volume. For local runs (no Vector), leave unset.
# VECTOR_LOG_DROP_DIR=/var/log/logpilot
#
# Loki labels:
# - LOKI_PARSER_LABEL: tagged on every push from the Python pipeline. Default "python".
# - LOKI_QUERY_PARSER: query-side filter applied automatically. Default "python".
#   Flip to "vector" during cutover. Set empty to disable filtering (sees both).
# LOKI_PARSER_LABEL=python
# LOKI_QUERY_PARSER=python

# Knowledge sources.
#
# Docker (default): set HOST paths below. Compose bind-mounts each one at a
# fixed container path (/knowledge/code and /knowledge/docs respectively) and
# the backend container sees those fixed paths via KNOWLEDGE_CODE_SOURCES /
# KNOWLEDGE_DOC_SOURCES set in docker-compose.yaml. Leave either unset to skip
# that source (compose falls back to an empty in-repo directory).
# KNOWLEDGE_CODE_HOST_PATH=/path/to/repo
# KNOWLEDGE_DOC_HOST_PATH=/path/to/docs
#
# Backend running on the host (uv run fastapi dev): set the SOURCES vars
# directly to host paths. The HOST_PATH vars are ignored in this case.
# KNOWLEDGE_CODE_SOURCES=/path/to/repo-one,/path/to/repo-two
# KNOWLEDGE_DOC_SOURCES=/path/to/docs-one,/path/to/docs-two
