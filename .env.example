# LogPilot — copy to .env and set values
# Required for AI agent (report generation):
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
EMBEDDING_MODEL=

# Optional: override when running backend locally (defaults used in Docker)
# LOKI_URL=http://localhost:3100
# PROMETHEUS_URL=http://localhost:9090
# QDRANT_URL=http://localhost:6333
# DATA_DIR=./data
# Knowledge sources: comma-separated paths. Local: use as-is.
# Docker: single path is mounted at /knowledge; for multiple paths set KNOWLEDGE_SOURCES_MOUNT to common parent.
# KNOWLEDGE_SOURCES=/path/to/docs,/path/to/repo
# KNOWLEDGE_SOURCES_MOUNT=/path/to/parent   # Docker only, for multiple paths